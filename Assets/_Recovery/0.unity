  dialoguePanel: {fileID: 710859066}
  speakerNameText: {fileID: 758252129}
  dialogueText: {fileID: 257536107}
  portraitImage: {fileID: 1490211540}
  audioSource: {fileID: 688838204}
  textBlip: {fileID: 0}
  textSpeed: 0.04
  blipInterval: 0.05
  spriteEntries:
  - key: mia neutral
    sprite: {fileID: 21300000, guid: e9b6620c2609349439516720a3d396ae, type: 3}
  - key: mia annoyed
    sprite: {fileID: 21300000, guid: 4aab61e7e9630c44ab44ce53f6d8dc73, type: 3}
  - key: mia happy
    sprite: {fileID: 21300000, guid: 9493c6017c07e4b4a8d04fdcfe409815, type: 3}
  - key: mia sad
    sprite: {fileID: 21300000, guid: c40b438a6e163744d8224539634e3de6, type: 3}
  - key: mia shocked
    sprite: {fileID: 21300000, guid: d38a850493e4ccc409571713db0db92e, type: 3}
  - key: miku
    sprite: {fileID: 10917, guid: 0000000000000000f000000000000000, type: 0}
  lines:
  - speaker: 0
    text: what..
    spriteKey: mia sad
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 0
    text: what am i doing here...?
    spriteKey: mia shocked
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 0
    text: what is this place?
    spriteKey: mia sad
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 1
    text: are you okay?
    spriteKey: miku
    voiceClip: {fileID: 8300000, guid: c2506beb88132104ea1b47d4ee27ba99, type: 3}
  - speaker: 0
    text: AREDCGFDXHFGD
    spriteKey: mia shocked
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 1
    text: it's miku
    spriteKey: miku
    voiceClip: {fileID: 8300000, guid: a729e705d3781d847a3107d63a4657d4, type: 3}
  - speaker: 0
    text: HUH
    spriteKey: mia annoyed
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 1
    text: what are you doing here?
    spriteKey: miku
    voiceClip: {fileID: 8300000, guid: 6d8cbc1d08e54bc41a39f3071506b822, type: 3}
  - speaker: 0
    text: i..i..don't know but I don't think this is my SEKAI..
    spriteKey: mia sad
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 1
    text: You're lost?
    spriteKey: miku
    voiceClip: {fileID: 8300000, guid: 2fa2d867c574cd94e93d2d826bf7e16c, type: 3}
  - speaker: 0
    text: I think so..
    spriteKey: mia neutral
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
  - speaker: 1
    text: Just follow me
    spriteKey: miku
    voiceClip: {fileID: 8300000, guid: a00016bd405806d4494cd2d20963f284, type: 3}
  - speaker: 0
    text: Okay thanks miku
    spriteKey: mia happy
    voiceClip: {fileID: 8300000, guid: 578042185c6db664ebec4a75db654d8e, type: 3}
